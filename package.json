{
  "name": "@nestjs/typeorm",
  "version": "11.0.1",
  "description": "Nest - modern, fast, powerful node.js web framework (@typeorm)",
  "author": "Kamil Mysliwiec",
  "license": "MIT",
  "url": "https://github.com/nestjs/typeorm#readme",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "format": "prettier --write \"**/*.ts\"",
    "lint": "oxlint",
    "prepublish:npm": "npm run build",
    "publish:npm": "npm publish --access public",
    "prepublish:next": "npm run build",
    "publish:next": "npm publish --access public --tag next",
    "test:e2e": "vitest run --sequence.sequential",
    "test:e2e:dev": "vitest --sequence.sequential",
    "prerelease": "npm run build",
    "release": "release-it",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.3",
    "@commitlint/config-angular": "20.5.3",
    "@nestjs/common": "11.1.19",
    "@nestjs/core": "11.1.19",
    "@nestjs/platform-express": "11.1.19",
    "@nestjs/testing": "11.1.19",
    "@types/node": "24.12.2",
    "@types/supertest": "7.2.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "mysql": "2.18.1",
    "oxlint": "1.62.0",
    "pg": "8.20.0",
    "prettier": "3.8.3",
    "reflect-metadata": "0.2.2",
    "release-it": "20.0.1",
    "rxjs": "7.8.2",
    "supertest": "7.2.2",
    "typeorm": "0.3.28",
    "typescript": "~6.0.2",
    "vitest": "4.1.5"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.2.0",
    "typeorm": "^0.3.0 || ^1.0.0-dev"
  },
  "lint-staged": {
    "**/*.{ts,json}": []
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nestjs/typeorm"
  }
}
